# ==============================================================================
# ZABBIX PROXY & BRANCH NODE CONFIGURATION / НАЛАШТУВАННЯ ПРОКСІ ТА ВУЗЛА ФІЛІЇ
# ==============================================================================

# --- TAILSCALE NETWORK SETTINGS / МЕРЕЖЕВІ НАЛАШТУВАННЯ TAILSCALE ---

# Unique device name in the Tailscale admin console
# Унікальне ім'я пристрою в панелі Tailscale
TS_HOSTNAME=branch-node-name

# Authentication key (get a fresh one from Tailscale console if expired)
# Ключ авторизації (візьміть свіжий у консолі Tailscale, якщо старий прострочено)
TS_AUTHKEY=tskey-auth-YOUR_KEY_HERE

# Advertised routes: e.g., local subnets 192.168.10.0/24
# Маршрути, які ми публікуємо: наприклад, локальні підмережі 192.168.10.0/24
TS_ROUTES=192.168.10.0/24


# --- ZABBIX PROXY SETTINGS / НАЛАШТУВАННЯ ZABBIX ПРОКСІ ---

# Must exactly match the Proxy name in the Zabbix Server web UI
# Має точно збігатися з ім'ям Proxy в інтерфейсі Zabbix Server
ZBX_PROXY_NAME=Proxy-Branch-Name

# Internal IP address of your central Zabbix Server in the Tailscale network
# Внутрішня IP-адреса вашого центрального Zabbix-сервера в мережі Tailscale
ZBX_SERVER_HOST=100.x.y.z


# --- NODE AGENT SETTINGS / НАЛАШТУВАННЯ АГЕНТА ВУЗЛА ---

# Internal hostname for self-monitoring. MUST MATCH Host name in UI!
# Внутрішнє ім'я для самомоніторингу. МАЄ ЗБІГАТИСЯ з Host name в інтерфейсі!
ZBX_HOSTNAME_PROXY_NODE=Host-Branch-Name

# Allowed servers for Agent: 127.0.0.1 (local proxy) and Docker Bridge for host monitoring
# Дозволені сервери для агента: 127.0.0.1 (локальний проксі) та Docker Bridge для моніторингу хоста
ZBX_AGENT_ALLOWED_SERVERS=127.0.0.1,100.x.y.z,172.17.0.0/16


# --- GLOBAL SETTINGS / ЗАГАЛЬНІ НАЛАШТУВАННЯ ---

# System timezone / Часовий пояс системи
TIMEZONE=Europe/Kyiv


# --- DIRECTORY PATHS / ШЛЯХИ ДО ДИРЕКТОРІЙ ---

# Relative or absolute paths for persistent data
# Відносні або абсолютні шляхи для постійних даних
PATH_TS_STATE=./tailscale_state
PATH_ZBX_DB=./zabbix_proxy_db
PATH_SNMPTRAPS=./snmptraps