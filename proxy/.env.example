# --- TAILSCALE NETWORK SETTINGS / МЕРЕЖЕВІ НАЛАШТУВАННЯ TAILSCALE ---

# Unique device name in the Tailscale admin console
# Унікальне ім'я пристрою в панелі Tailscale
TS_HOSTNAME=city-branch-name 

# Authentication key (get a fresh one from Tailscale console if expired)
# Ключ авторизації (візьміть свіжий у консолі Tailscale, якщо старий прострочено)
TS_AUTHKEY=tskey-auth-YOUR_KEY_HERE 

# Advertised routes: e.g., local subnets 192.168.10.0/24, 172.26.27.0/28, and /32 for a single host
# Маршрути, які ми публікуємо: наприклад, 192.168.10.0/24, 172.26.27.0/28 підмережі та /32 для одного хоста
TS_ROUTES=192.168.10.0/24,172.26.27.0/28,192.168.20.22/32


# --- ZABBIX SETTINGS / НАЛАШТУВАННЯ ZABBIX ---

# Must exactly match the Proxy name in the Zabbix Server web UI
# Має точно збігатися з ім'ям Proxy в інтерфейсі Zabbix Server
PROXY_HOSTNAME=Proxy-Branch-Name 

# Must exactly match the Host name in the Zabbix Server web UI
# Має точно збігатися з ім'ям Host (агента) в інтерфейсі Zabbix Server
AGENT_HOSTNAME=Host-Branch-Name 

# Internal IP address of your central Zabbix Server in the Tailscale network
# Внутрішня IP-адреса вашого центрального Zabbix-сервера в мережі Tailscale
ZBX_SERVER_IP=100.XX.XX.XX 


# --- HOST PATHS (UBUNTU/PROXMOX) / ШЛЯХИ НА ХОСТІ ---

# Local directories relative to the docker-compose.yml location
# Локальні папки відносно розташування docker-compose.yml

# Path for SNMP trap logs / Шлях для логів SNMP-трапів
PATH_SNMPTRAPS=./snmptraps 

# Path for Zabbix Proxy SQLite database / Шлях для бази даних Zabbix Proxy
PATH_ZABBIX_DB=./zabbix_db 

# Path for Tailscale state and keys / Шлях для стану та ключів Tailscale
PATH_TS_STATE=./tailscale_state 

# Path for custom and standard SNMP MIB files / Шлях для MIB-файлів SNMP
PATH_MIBS=./mibs