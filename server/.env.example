# ==============================================================================
# ZABBIX SERVER CONFIGURATION / НАЛАШТУВАННЯ СЕРВЕРА ZABBIX
# ==============================================================================

# --- DATABASE / БАЗА ДАНИХ (PostgreSQL + TimescaleDB) ---
# Database user and password / Користувач та пароль бази даних
POSTGRES_USER=zabbix
POSTGRES_PASSWORD=CHANGEME_SECURE_PASSWORD
POSTGRES_DB=zabbix

# --- ZABBIX CORE / ЯДРО ZABBIX ---
# Visible name in the web interface / Ім'я, яке відображається у веб-інтерфейсі
ZBX_SERVER_NAME=Cloud_Monitoring_Center
# Internal hostname for self-monitoring. MUST MATCH Host name in UI!
# Внутрішнє ім'я для самомоніторингу. МАЄ ЗБІГАТИСЯ з Host name в інтерфейсі!
ZBX_HOSTNAME_SERVER=Zabbix_Cloud_Server
# Performance tuning / Налаштування продуктивності
ZBX_CACHELINESIZE=128

# --- TAILSCALE TUNNEL / ТУНЕЛЬ TAILSCALE ---
# Tailscale Auth Key configuration / Налаштування ключа авторизації Tailscale
# 1. LEAVE EMPTY if you don't have a key yet. After deployment, get the login link from: `docker logs ts-server`
# 1. ЗАЛИШТЕ ПУСТИМ, якщо у вас ще немає ключа. Після розгортання отримайте посилання через: `docker logs ts-server`
# 2. OR PASTE YOUR KEY here if you already have one generated in the Tailscale console.
# 2. АБО ВСТАВТЕ ВЛАСНИЙ КЛЮЧ тут, якщо ви вже згенерували його в консолі Tailscale.
TS_AUTHKEY=
# Device name in Tailscale network / Ім'я пристрою в мережі Tailscale
TS_HOSTNAME_SERVER=zabbix-cloud-hub

# --- SYSTEM / СИСТЕМА ---
# Timezone for logs and web interface / Часовий пояс для логів та веб-інтерфейсу
TIMEZONE=Europe/Kyiv